### ============ 10. ELIMINAR RECETA (ID=3) ============
### Nota: Asegúrate de que la receta no sea usada por un producto

DELETE {{baseUrl}}/api/admin/recipes/3
Authorization: Bearer {{adminToken}}

### ============ 11. INTENTAR OBTENER RECETA ELIMINADA (ID=3) ============
### Debe retornar 404 Not Found

GET {{baseUrl}}/api/admin/recipes/3
Authorization: Bearer {{adminToken}}

### ============ 12. OBTENER TODAS RECETAS NUEVAMENTE ============

GET {{baseUrl}}/api/admin/recipes
Authorization: Bearer {{adminToken}}

### ============ CASOS DE ERROR A PROBAR ============

### ERROR 1: Crear receta sin itemDetails
POST {{baseUrl}}/api/admin/recipes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Receta Sin Items",
  "quantity": 1,
  "description": "Esta receta no tiene items",
  "itemDetails": []
}

### Error esperado: 400 - "Una receta debe tener al menos un item detail"

### ERROR 2: Crear receta con itemId inválido
POST {{baseUrl}}/api/admin/recipes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Receta Con Item Inválido",
  "quantity": 1,
  "description": "Intentando usar un item que no existe",
  "itemDetails": [
    {
      "itemId": 99999,
      "quantity": 100,
      "annotation": "",
      "isOptional": false
    }
  ]
}

### Error esperado: 404 - "Item no encontrado: 99999"

### ERROR 3: Obtener receta que no existe
GET {{baseUrl}}/api/admin/recipes/99999
Authorization: Bearer {{adminToken}}

### Error esperado: 404 - "Receta no encontrada: 99999"

### ERROR 4: Actualizar receta que no existe
PUT {{baseUrl}}/api/admin/recipes/99999
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Receta Fantasma",
  "quantity": 1,
  "description": "Esta receta no existe",
  "itemDetails": [
    {
      "itemId": 1,
      "quantity": 100,
      "annotation": "",
      "isOptional": false
    }
  ]
}

### Error esperado: 404 - "Receta no encontrada: 99999"

### ERROR 5: Eliminar receta que no existe
DELETE {{baseUrl}}/api/admin/recipes/99999
Authorization: Bearer {{adminToken}}

### Error esperado: 404 - "Receta no encontrada: 99999"

### ============ CASOS DE FLUJO COMPLETO ============

### FLUJO: Crear receta y usarla en un producto

### Paso 1: Crear receta
POST {{baseUrl}}/api/admin/recipes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Sandwich de Jamón",
  "quantity": 1,
  "description": "Sandwich clásico de jamón y queso",
  "itemDetails": [
    {
      "itemId": 30,
      "quantity": 2,
      "annotation": "pan blanco tostado",
      "isOptional": false
    },
    {
      "itemId": 31,
      "quantity": 100,
      "annotation": "jamón de pavo",
      "isOptional": false
    },
    {
      "itemId": 32,
      "quantity": 50,
      "annotation": "queso suizo",
      "isOptional": false
    },
    {
      "itemId": 33,
      "quantity": 50,
      "annotation": "lechuga",
      "isOptional": true
    }
  ]
}

### Guardar el ID de la receta (ej: 4)
### Luego crear un producto usando esta receta
### Ver: /api/admin/products

### ============ NOTAS IMPORTANTES ============

# 1. REEMPLAZAR TOKENS:
#    - Reemplaza {{adminToken}} con tu JWT válido
#    - Puedes obtener tokens en POST /api/auth/login
#
# 2. IDS DE ITEMS:
#    - Los itemIds (1, 2, 3, etc.) son ejemplos
#    - Reemplázalos con IDs reales de tu BD
#
# 3. VALIDACIONES:
#    - name: no puede estar vacío
#    - quantity: debe ser > 0
#    - itemDetails: mínimo 1 item
#    - itemId: debe existir y estar activo
#
# 4. REEMPLAZO DE ITEMS:
#    - Al actualizar, los itemDetails se reemplazan completamente
#    - No se mezclan con los anteriores
#
# 5. RESTRICCIONES:
#    - No puedes eliminar recetas usadas por productos
#    - Los items deben estar activos
#
# 6. RESPUESTAS:
#    - 201: Creación exitosa
#    - 200: Actualización exitosa
#    - 204: Eliminación exitosa (sin body)
#    - 400: Errores de validación
#    - 404: Recurso no encontrado
#    - 401: No autenticado
#    - 403: No autorizado


